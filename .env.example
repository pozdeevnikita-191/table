# Скопируйте этот файл в .env и заполните значения.
# .env НЕ должен попадать в git (см. .gitignore) — на Timeweb Cloud эти
# переменные задаются в панели App Platform, а не через файл .env.

# Порт, на котором слушает приложение внутри контейнера (App Platform сам
# пробросит его наружу — обычно трогать не нужно).
PORT=3000

# Строка подключения к PostgreSQL.
# Если используете свою управляемую БД в Timeweb Cloud — возьмите строку
# подключения из панели (Базы данных -> ваш кластер -> Подключение).
# Если поднимаете Postgres через docker-compose.yml — оставьте значение,
# согласованное с переменными ниже.
DATABASE_URL=postgres://tabele:tabele@db:5432/tabele

# Используются только сервисом db в docker-compose.yml (локальный Postgres).
POSTGRES_USER=tabele
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tabele
